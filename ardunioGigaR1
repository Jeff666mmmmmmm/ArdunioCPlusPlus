  }
}

// Computes the delay for the *next* step given how many steps remain
static inline unsigned long easeOutDelayMs(
  int totalSteps,
  int stepsRemaining,
  float baseDelayMs,
  unsigned long easeOutTimeMs,
  float endSlowMult
) {
  if (totalSteps <= 0) return (unsigned long)(baseDelayMs + 0.5f);

  // Convert time budget into “how many steps are in the easing zone”
  // Example: baseDelay=5ms, easeOutTime=500ms -> ~100 steps of easing zone
  int zoneSteps = (int)((float)easeOutTimeMs / baseDelayMs + 0.5f);
  if (zoneSteps < 1) zoneSteps = 1;
  if (zoneSteps > totalSteps) zoneSteps = totalSteps;

  if (stepsRemaining > zoneSteps) {
    return (unsigned long)(baseDelayMs + 0.5f); // cruising
  }

  // t=0 at start of easing zone, t=1 at final step
  float t = 1.0f - ((float)stepsRemaining / (float)zoneSteps);
  float eased = smoothstep(t);

  float delayMs = baseDelayMs * (1.0f + eased * (endSlowMult - 1.0f));
  return (unsigned long)(delayMs + 0.5f);
}

