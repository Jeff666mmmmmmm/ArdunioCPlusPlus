void keepWifiAlive(){
  
    if (lastArduinoCloudUpdateAttempt + 4000 < millis()) {

      sendBulkData();

      // Update Cloud
      ArduinoCloud.update();

      lastArduinoCloudUpdateAttempt = millis();
  
