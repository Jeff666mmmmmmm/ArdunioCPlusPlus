void ErrorScript(String ErrorText){

  // Turn on error led light
  digitalWrite(errorLedPin, HIGH);

  scriptErrorPaused = true;

  previousErrorReason = lastErrorReason; 
  lastErrorReason = ErrorText;

  // Send out text with prefix E for proper error formate server side
  sendOutData("E" + ErrorText);
