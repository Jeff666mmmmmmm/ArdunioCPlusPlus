// Move specific motor
static inline bool stepAxisOnce(MotorAxis axis, bool forward, bool ignoreBounds) {
  switch (axis) {
    case AXIS_X: return forward ? stepMotorXForward(ignoreBounds) : stepMotorXBackward(ignoreBounds);
    case AXIS_Z: return forward ? stepMotorZForward(ignoreBounds) : stepMotorZBackward(ignoreBounds);
    case AXIS_R: return forward ? stepMotorRForward(ignoreBounds) : stepMotorRBackward(ignoreBounds);
    default: return false;
  }
}


// Move Steps axis, absolute/relative, forward/back
bool moveAxisSteps(
  MotorAxis axis,
  bool isAbsolute,
  bool forward,
  long stepAmount,
  float baseDelayMs,
  bool easeOut,
  bool ignoreBounds
) {
  // Position pointers (your positions are volatile int) :contentReference[oaicite:2]{index=2}
  volatile int* posPtr = nullptr;
  int maxStep = 0;

  switch (axis) {
    case AXIS_X: posPtr = &motorStepPositionX; maxStep = maxXStep; break;
    case AXIS_Z: posPtr = &motorStepPositionZ; maxStep = maxZStep; break;
    case AXIS_R: posPtr = &motorStepPositionR; maxStep = 0; break; // R has no max in your setup
    default: ErrorScript("MoveAxisSteps Axis Invalid (" + String(axis) + ")"); return false;
  }

  long startPos = (long)(*posPtr);
  long target   = startPos;

  if (isAbsolute) {
    target = stepAmount;
    // Bounds only apply to axes that actually have a max
    if (!ignoreBounds && axis != AXIS_R) {
      if (target < 0 || target > (long)maxStep){
        ErrorScript("Absolute Target not within bounds (" + String(target) + ") (" + String(axis) + ")");
        return false;
      }
    }
  } else {
    // relative: stepAmount is a magnitude (can be +/- too, we normalize)
    long delta = stepAmount;
    if (delta < 0) { delta = -delta; forward = !forward; }
    target = startPos + (forward ? delta : -delta);

    if (!ignoreBounds && axis != AXIS_R) {
      if (target < 0) target = 0;
      if (target > (long)maxStep) target = (long)maxStep;
    }
  }

  long totalSteps = labs(target - startPos);
  if (totalSteps <= 0) return true;

  // Step using your existing helper (DO NOT use stepPulseX/Z/R; they don't exist) :contentReference[oaicite:3]{index=3}
  for (long moved = 0; moved < totalSteps; ++moved) {
    bool dirForward = (target > (long)(*posPtr));
    if (!stepAxisOnce(axis, dirForward, ignoreBounds)) return false; // :contentReference[oaicite:4]{index=4}

    unsigned long d = (unsigned long)(baseDelayMs + 0.5f);
    if (easeOut) {
      long remaining = (totalSteps - 1) - moved;
      d = easeOutDelayMs(
        (int)totalSteps,
        (int)remaining,
        baseDelayMs,
        EASE_OUT_TIME_MS,
        EASE_END_SLOW_MULT
      );
    }
    delay(d);
  }

  return true;
}

// Change motor heat sink fans status
void runFans(bool run) {

  // Fans on, requested off
  if (heatSinkFansRunning && !run) {

    // Fans currently running
    heatSinkFansRunning = false;
    digitalWrite(ENABLE_PIN_FAN, LOW);

    // Change update
    lastFanChange = millis();

    // Fans off, requested to run
  } else if (!heatSinkFansRunning && run) {

    // Fans currently running
    heatSinkFansRunning = true;
    digitalWrite(ENABLE_PIN_FAN, HIGH);

    // Change update
    lastFanChange = millis();
  }
}

// Energize Step motors
void stepMotorsActivated(bool run) {
  
  if (run) {
    digitalWrite(ENABLE_PIN_MOTOR, HIGH);
    digitalWrite(ENABLE_PIN_MOTORY, HIGH);
    runFans(true);
  } else {
    digitalWrite(ENABLE_PIN_MOTOR, LOW);
    digitalWrite(ENABLE_PIN_MOTORY, LOW);
    runFans(false);
  }

  // Delay to ensure coils have time to energize
delay(50);
}

// Energize Y Step motors
void stepMotorsYActivated(bool run) {
  
  if (run) {
    digitalWrite(ENABLE_PIN_MOTORY, HIGH);
  } else {
    digitalWrite(ENABLE_PIN_MOTORY, LOW);
  }

  // Delay to ensure coils have time to energize
delay(50);
}


// two-digit "ms" field: "XY" -> X.Y milliseconds (0.0..9.9)
static inline float parseTwoDigitMs(const String& s, int off = 0) {
  int d0 = s.charAt(off) - '0';
  int d1 = s.charAt(off + 1) - '0';
  if (d0 < 0 || d0 > 9 || d1 < 0 || d1 > 9) return 0.0f;
  return d0 + d1 * 0.1f;
}

// Return slot index [0..numCommands-1] that holds the payload id62, or -1 if absent
int findSlotById62(const String& id62) {
  for (int i = 0; i < numCommands; i++) {
    // Each command string starts with its 5-character base62 ID
    if (commands[i].length() >= 5 && commands[i].substring(0, 5) == id62) {
      return i;
    }
  }
  return -1;
}

// Count empty slots across ALL 20
int countEmptySlotsAll() {
  int c = 0;
  for (int i = 0; i < numCommands; i++)
    if (commands[i].length() == 0) c++;
  return c;
}

// Generic homing routine for one axis
static bool homeOneAxis(
  const char* axisName,
  int leverPin,
  int maxStep,
  int stepsPerInch,
  int stepDelayMs,
  bool (*stepForward)(bool),
  bool (*stepBackward)(bool),
  volatile int& stepPositionVar,
  volatile int& stepCompletionVar) {

  // Approach the switch (ignore bounds while seeking home)
  for (int i = 0; i < round(maxStep + (stepsPerInch)*2); ++i) {
    if (!stepForward(true)) {
// Error script
      ErrorScript("Home " + String(axisName) + " step forward failed");
      return false;
    }
    delay(stepDelayMs);

    bool isZ = (leverPin == PressureLever_ReadZ);
    bool pressed = leverPressedAxis(leverPin, isZ ? Z_LEVER_ACTIVE_HIGH : X_LEVER_ACTIVE_HIGH);
    if (pressed) {
      // We hit the lever. Back off ~1 inch to clear it first
      delay(35);
      for (int j = 0; j < round(0.5 * stepsPerInch); ++j) {
        if (!stepBackward(true)) {
// Error script
      ErrorScript("Home " + String(axisName) + " backoff failed");
          return false;
        }
        delay(stepDelayMs);
      }

      pressed = leverPressedAxis(leverPin, isZ ? Z_LEVER_ACTIVE_HIGH : X_LEVER_ACTIVE_HIGH);
      if (pressed) {
// Error script
      ErrorScript("Home " + String(axisName) + " lever still HIGH after backoff");
        return false;
      }

      // ✅ Define zero *here*, at the cleared position.
      stepPositionVar = 0;
      stepCompletionVar = 0;
      return true;
    }
  }

// Never triggered within travel error script
      ErrorScript("Home " + String(axisName) + " never triggered lever");
  return false;
}

// Read R lever
static inline bool readRLeverStable(uint8_t samples = 5, uint8_t settleMs = 2) {
  uint8_t pressedCount = 0;
  for (uint8_t i = 0; i < samples; i++) {
    if (leverPressedAxis(PressureLever_ReadR, R_LEVER_ACTIVE_HIGH)) pressedCount++;
    delay(settleMs);
  }
  return pressedCount > (samples / 2);
}

// Home R axis
bool homeRotationAxisR() {
  if (scriptErrorPaused) return false;

  // Safety limits
  const long maxSearchSteps = 24L * arduinoMotorStepsPerInch;
  const long maxRevSteps    = 20L * arduinoMotorStepsPerInch; // allow >1 rev if needed
  const int  stepDelayMs    = 14;                             // slow homing speed

  // How far to move away from the lever after each edge (so we’re not sitting on it)
  const int edgeClearSteps = 6; // tweak

  auto stepF = [&]() -> bool { return stepMotorRForward(true);  };
  auto stepB = [&]() -> bool { return stepMotorRBackward(true); };

  // --- Helper: ensure we start NOT pressed ---
  long guard = 0;
  while (readRLeverStable() && guard < maxSearchSteps) {
    if (!stepF()) { ErrorScript("Home R: failed clearing pressed window"); return false; }
    delay(stepDelayR);
    guard++;
  }
  if (guard >= maxSearchSteps) { ErrorScript("Home R: stuck pressed"); return false; }

  // --- Helper: find entry edge (not pressed -> pressed) going forward ---
  auto seekPressedForward = [&](long limit) -> bool {
    for (long i = 0; i < limit; i++) {
      if (!stepF()) return false;
      delay(stepDelayMs);
      if (readRLeverStable()) return true;
    }
    return false;
  };

  // --- Helper: find exit edge (pressed -> not pressed) continuing forward ---
  auto seekReleasedForward = [&](long limit, long& outWidthSteps) -> bool {
    outWidthSteps = 0;
    // Assume currently pressed
    for (long i = 0; i < limit; i++) {
      outWidthSteps++;
      if (!stepF()) return false;
      delay(stepDelayMs);
      if (!readRLeverStable()) return true; // now released
    }
    return false;
  };

// --- 1) Find the first pressed window entry ---
if (!seekPressedForward(maxSearchSteps)) {
  ErrorScript("Home R: never hit lever");
  return false;
}

// Tighten the edge: back a little then re-approach
for (int i = 0; i < 2; i++) { if (!stepB()) return false; delay(stepDelayMs); }
if (!seekPressedForward(20)) { ErrorScript("Home R: re-approach failed"); return false; }

long enterStep = motorStepPositionR;

// --- 2) Continue until released (measure width) ---
long widthSteps = 0;
if (!seekReleasedForward(maxSearchSteps, widthSteps) || widthSteps <= 0) {
  ErrorScript("Home R: failed measuring window width");
  return false;
}

long exitStep = motorStepPositionR;

// --- 3) Go to midpoint using enter/exit ---
long midStep = (enterStep + exitStep) / 2;

while (motorStepPositionR != midStep) {
  if (motorStepPositionR > midStep) {
    if (!stepF()) { ErrorScript("Home R: move to midpoint failed (fwd)"); return false; }
  } else {
    if (!stepB()) { ErrorScript("Home R: move to midpoint failed (bwd)"); return false; }
  }
  delay(stepDelayMs);
}

// --- 4) Verify we’re on the lever; if not, recover and re-measure ---
if (!readRLeverStable()) {
  bool found = false;

  for (int k = 0; k < 20; k++) { if (!stepF()) return false; delay(stepDelayMs); if (readRLeverStable()) { found = true; break; } }
  if (!found) {
    for (int k = 0; k < 40; k++) { if (!stepB()) return false; delay(stepDelayMs); if (readRLeverStable()) { found = true; break; } }
  }
  if (!found) {
    ErrorScript("Home R: couldn't re-find window near midpoint");
    return false;
  }

  // Re-measure properly now that we’re back inside the window
  long guard2 = 0;
  while (readRLeverStable() && guard2++ < maxSearchSteps) { if (!stepB()) return false; delay(stepDelayMs); } // ensure released
  if (!seekPressedForward(maxSearchSteps)) { ErrorScript("Home R: re-seek enter failed"); return false; }
  long enter2 = motorStepPositionR;

  long w2 = 0;
  if (!seekReleasedForward(maxSearchSteps, w2) || w2 <= 0) { ErrorScript("Home R: re-seek exit failed"); return false; }
  long exit2 = motorStepPositionR;

  long mid2 = (enter2 + exit2) / 2;
  while (motorStepPositionR != mid2) {
    if (motorStepPositionR > mid2) { if (!stepF()) return false; }
    else                          { if (!stepB()) return false; }
    delay(stepDelayMs);
  }

  if (!readRLeverStable()) {
    ErrorScript("Home R: midpoint still not pressed after recovery");
    return false;
  }
}

  // --- Optional: hop a few steps off the lever so you’re not resting on it ---
  for (int i = 0; i < edgeClearSteps; i++) {
    if (!stepB()) return false; // move slightly away (choose direction that leaves it released or stable)
    delay(stepDelayMs);
  }
  // Now go forward the same amount to return to midpoint exactly (keeps tension consistent)
  for (int i = 0; i < edgeClearSteps; i++) {
    if (!stepF()) return false;
    delay(stepDelayMs);
  }

  // Define “sensor center” as step 0
  motorStepPositionR = 0;
  stepsfromRstartRotation = 0;

  // --- 3) Measure steps per revolution: from this midpoint to the NEXT midpoint ---
  // From midpoint, move forward until we hit pressed again (next window entry)
  long stepsToNextPress = 0;
  guard = 0;

  // ensure we’re released first (if midpoint puts you pressed sometimes)
  while (readRLeverStable() && guard < maxSearchSteps) {
    if (!stepF()) { ErrorScript("Home R: failed exiting window from midpoint"); return false; }
    delay(stepDelayMs);
    stepsToNextPress++;
    guard++;
  }

  guard = 0;
  while (!readRLeverStable() && guard < maxRevSteps) {
    if (!stepF()) { ErrorScript("Home R: failed seeking next window"); return false; }
    delay(stepDelayR);
    stepsToNextPress++;
    guard++;
  }
  if (guard >= maxRevSteps) { ErrorScript("Home R: never saw lever again"); return false; }

  // Now we’re inside the next pressed window entry; measure its width and go to its midpoint
  long width2 = 0;
  if (!seekReleasedForward(maxSearchSteps, width2) || width2 <= 0) {
    ErrorScript("Home R: failed measuring second window");
    return false;
  }

  const long midOffset2 = width2 / 2;
  const long backToMid2 = width2 - midOffset2;

  for (long i = 0; i < backToMid2; i++) {
    if (!stepB()) { ErrorScript("Home R: failed backing to 2nd midpoint"); return false; }
    delay(stepDelayMs);
  }

  // Total steps per revolution (midpoint->midpoint)
  long stepsPerRev = stepsToNextPress + midOffset2;
  if (stepsPerRev <= 0) stepsPerRev = 1;
  R_stepsPerRevolution = (int)stepsPerRev;

// Convert degrees to steps using the measured steps-per-rev
long offsetSteps = (long)round((double)R_stepsPerRevolution * (double)R_HOME_LOGICAL_OFFSET_DEG / 360.0);

// Choose direction: +deg means forward. If your "forward" is opposite, flip this.
bool offsetForward = true; // set false if you need opposite

// Perform the physical move
for (long i = 0; i < labs(offsetSteps); i++) {
  bool ok = offsetForward ? stepMotorRForward(true) : stepMotorRBackward(true);
  if (!ok) {
    ErrorScript("Home R: failed applying logical offset steps");
    return false;
  }
  delay(stepDelayR);
}

// NOW define this new position as zero (true home)
motorStepPositionR = 0;
currentRotationOfHead = 0;

return true;
}

// Home Y axis: seek lever -> relax -> re-energize -> offset 1 step -> set home
bool homeYAxis() {
  if (scriptErrorPaused) return false;

  // Make motor Y enabled
  stepMotorsYActivated(true);

  int currentStepDelay = 14;

 // Ensure step delay above min delay
    currentStepDelay = (currentStepDelay > minYStepDelay) ? currentStepDelay : minYStepDelay;

    // Move up
    int steps = 0;
    while (!leverPressedAxis(PressureLever_ReadY, Y_LEVER_ACTIVE_HIGH) && steps < maxYStep) {
      if (!stepMotorYForward(true)) return false;
      delay((unsigned long)currentStepDelay);
      steps++;
    }

  // If we timed out without seeing the lever, fail (don't lie about home)
  if (!leverPressedAxis(PressureLever_ReadY, Y_LEVER_ACTIVE_HIGH)) {
    ErrorScript("HomeY timeout: lever not hit within maxYStep=" + String(maxYStep));
    return false;
  }

  // Disable Y to drop and settle
  stepMotorsYActivated(false);
  delay(2500);

  // Reenable Y Motors
stepMotorsYActivated(true);

  // Step to lock motor
  if (!stepMotorYForward(true)) return false;

  //Set as home
  motorStepPositionY = 0;

  return true;
}

// Homes Stepper Motors; returns true only if all succeed.
bool homeStepperMotorsPositions() {

  // Ensure motors are powered while homing
  stepMotorsActivated(true);
  checkSwitch();

  // Use your existing per-axis delays
  int useDelayX = stepDelayX > 0 ? stepDelayX : 4;
  int useDelayZ = stepDelayZ > 0 ? stepDelayZ : 4;

  // First, home X
  bool okX = homeOneAxis(
    "X",
    PressureLever_ReadX,
    maxXStep,
    arduinoMotorStepsPerInch,
    useDelayX,
    &stepMotorXForward,
    &stepMotorXBackward,
    motorStepPositionX,
    motorStepCompletionX);

  if (!okX) {
    stepMotorsActivated(false);
    return false;
  }
  
  checkSwitch();

  // Then, home Z
  bool okZ = homeOneAxis(
    "Z",
    PressureLever_ReadZ,
    maxZStep,
    arduinoMotorStepsPerInch,
    useDelayZ,
    &stepMotorZForward,
    &stepMotorZBackward,
    motorStepPositionZ,
    motorStepCompletionZ);

  if (!okZ) {
    stepMotorsActivated(false);
    return false;
  }
  
  checkSwitch();
  
  // Home rotation (R) using the magnetic index
bool okR = homeRotationAxisR();


  if (!okR) {
    stepMotorsActivated(false);
    return false;
  }
  
  checkSwitch();

  // Home Y axis and ensure working order
  bool okY = homeYAxis();

  if (!okY) {
    stepMotorsActivated(false);
    return false;
  }
  
  checkSwitch();

  // Shut off motors if error occured
  if (!(okX && okZ && okR && okY)) {
    stepMotorsActivated(false);
  }

  // If all run, return as true or not, false
  return (okX && okZ && okR && okY);
}

// --- Request policy helpers ---
static inline unsigned long b62u(const String& s) {
  if (s.length() == 0) return 0xFFFFFFFFUL;  // treat empty as "no limit" later
  return base62ToDecimal(s);
}

// Does this ID exist in storage
static inline bool slotHasId62(const String& id62) {
  return findSlotById62(id62) >= 0;
}

// True if the next payload IDs are all absent
bool nextSlotsMissing() {
  for (int i = 0; i < 5; ++i) {
    String id62 = decimalToBase62((unsigned long)(currentCommandNumberID + i), 5);
    if (slotHasId62(id62)) return false;  // found one present -> not "all missing"
  }
  return true;
}

// Find the closest missing payload id
bool findClosestMissingId62(String& outId62, unsigned long maxN, bool windowOnly) {
  unsigned long cur = (unsigned long)currentCommandNumberID;
  unsigned long limit = windowOnly ? (cur + 5) : maxN;

  if (maxN != 0xFFFFFFFFUL && limit > maxN) limit = maxN;
  for (unsigned long n = cur; n <= limit; ++n) {
    String id62 = decimalToBase62(n, 5);
    if (!slotHasId62(id62)) {
      outId62 = id62;
      return true;
    }
  }
  return false;
}

// Main gate for deciding if we should queue a request now
void requestNextIfPolicy() {
  if (finishedCurrentGcode) return;
  if (millis() - lastPayloadRequestTime <= ImportantMsgDelay) return;
  if (millis() - lastPayloadRequestTime <= PayloadMsgDelay) return;

  const int empties = countEmptySlotsAll();
  const bool lotsAheadAllMissing = nextSlotsMissing();
  if (!(empties >= 14 || lotsAheadAllMissing)) return;

  unsigned long maxN = b62u(maxPayloadToRequest);
  if (maxN == 0xFFFFFFFFUL) {
    // No cap provided; set a very large ceiling
    maxN = 0xFFFFFFF0UL;
  }

  // Try to find the closest missing within the next-6 window first
  String needId;
  bool found = findClosestMissingId62(needId, maxN, /*windowOnly=*/true);

  // If buffer is roomy search farther ahead up to maxN.
  if (!found && empties >= 14) {
    found = findClosestMissingId62(needId, maxN, /*windowOnly=*/false);
  }

  // Nothing missing in range up to maxN → either we’re loaded with all remaining
  if (!found) {
    return;
  }

  // Construct and queue the specific request
  String constructed = "R" + needId;

  sendOutData(constructed);
  lastPayloadRequestTime = millis();
  return;
}

